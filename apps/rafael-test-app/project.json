{
  "targets": {
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node tools/start-expo.js start --port 8081",
        "cwd": "apps/rafael-test-app"
      }
    },
    "run-android": {
      "executor": "@nx/expo:run",
      "options": {
        "platform": "android",
        "port": 8081,
        "device": "Medium_Phone_API_36.1",
        "variant": "debug"
      }
    }
  }
}
